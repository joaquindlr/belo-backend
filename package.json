{
  "name": "belo-backend",
  "version": "1.0.0",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "main": "app.ts",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "start": "npm run build && node dist/server.js",
    "build": "tsc",
    "watch": "tsc -w",
    "dev": "npm run clean && npm run build && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"npm:watch\" \"npm:dev:start\"",
    "dev:start": "node --watch dist/server.js",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "6.0.0",
    "@fastify/cors": "11.2.0",
    "@fastify/sensible": "6.0.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.6",
    "dotenv": "17.4.2",
    "fastify": "5.0.0",
    "fastify-cli": "8.0.0",
    "fastify-plugin": "5.0.0",
    "pg": "8.21.0",
    "reflect-metadata": "0.2.2",
    "typeorm": "1.0.0"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "25.0.3",
    "@types/pg": "8.20.0",
    "c8": "11.0.0",
    "concurrently": "9.0.0",
    "fastify-tsconfig": "3.0.0",
    "jest": "30.4.2",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "~5.9.2"
  }
}
